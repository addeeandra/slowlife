{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "slowlife",
  "version": "0.0.2",
  "identifier": "com.addeeandra.slowlife",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "slowlife",
        "label": "main",
        "width": 1100,
        "height": 700,
        "minWidth": 360,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
